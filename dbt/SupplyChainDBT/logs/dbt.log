    as (

with all_dates as (

    select order_date as full_date from SupplyChain_db.staging.stg_supply_chain
    where order_date is not null

    union

    select shipping_date as full_date from SupplyChain_db.staging.stg_supply_chain
    where shipping_date is not null

    union

    select movement_date as full_date from SupplyChain_db.staging.stg_supply_chain
    where movement_date is not null

),

distinct_dates as (

    select distinct full_date
    from all_dates

),

calendar as (

    select
        cast(to_char(full_date, 'YYYYMMDD') as int) as date_key,
        full_date,
        extract(day from full_date)                 as day,
        extract(month from full_date)                as month,
        extract(quarter from full_date)               as quarter,
        extract(year from full_date)                 as year,
        to_char(full_date, 'DY')                      as day_name,
        to_char(full_date, 'MON')                     as month_name
    from distinct_dates

)

select * from calendar


    )

