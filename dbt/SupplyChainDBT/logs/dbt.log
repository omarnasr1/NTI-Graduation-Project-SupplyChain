        Customer_Email                                           as customer_email,
        trim(Customer_Fname)                                     as customer_fname,
        trim(Customer_Lname)                                     as customer_lname,
        Customer_Password                                       as customer_password,
        trim(Customer_Segment)                                   as customer_segment,

