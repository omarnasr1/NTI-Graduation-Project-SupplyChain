  as (
    -- fact_order_item.sql


with stg as (

    select * from SupplyChain_db.staging.stg_supply_chain

),

cust as (
    select * from SupplyChain_db.marts.dim_customer
),

prod as (
    select * from SupplyChain_db.marts.dim_product
),

order_geo as (
    select * from SupplyChain_db.marts.dim_order_geography
),

ship_mode as (
    select * from SupplyChain_db.marts.dim_shipping_mode
),

delivery as (
    select * from SupplyChain_db.marts.dim_delivery_status
),

ord_status as (
    select * from SupplyChain_db.marts.dim_order_status
),

order_date_dim as (
    select * from SupplyChain_db.marts.dim_date
),

shipping_date_dim as (
    select * from SupplyChain_db.marts.dim_date
),

payment as (
    select * from SupplyChain_db.marts.dim_payment
),

joined as (

    select
        md5(cast(coalesce(cast(stg.order_item_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as order_item_key,
        stg.order_id,
        cust.customer_key,
        prod.product_key,
        order_geo.order_geography_key,
        ship_mode.shipping_mode_key,
        delivery.delivery_status_key,
        ord_status.order_status_key,
        order_date_dim.date_key       as order_date_key,
        shipping_date_dim.date_key    as shipping_date_key,
        payment.payment_key,
        stg.product_price,
        stg.sales,
        stg.sales_per_customer,
        stg.order_item_quantity,
        stg.order_item_product_price,
        stg.order_item_discount,
        stg.order_item_discount_rate,
        stg.order_item_total,
        stg.order_item_profit_ratio,
        stg.order_profit_per_order,
        stg.benefit_per_order
    from stg
    left join cust
        on stg.customer_fname  = cust.customer_fname
       and stg.customer_lname  = cust.customer_lname
       and stg.customer_segment = cust.customer_segment
       and stg.customer_email  = cust.customer_email
       and stg.customer_password = cust.customer_password
    left join prod
        on stg.product_name        = prod.product_name
       and stg.product_description = prod.product_description
       and stg.product_image       = prod.product_image
       and stg.product_status      = prod.product_status
    left join order_geo
        on stg.order_city    = order_geo.order_city
       and stg.order_state   = order_geo.order_state
       and stg.order_country = order_geo.order_country
       and stg.order_region  = order_geo.order_region
       and stg.market        = order_geo.market
    left join ship_mode
        on stg.shipping_mode = ship_mode.shipping_mode
    left join delivery
        on stg.delivery_status = delivery.delivery_status
    left join ord_status
        on stg.order_status = ord_status.order_status
    left join order_date_dim
        on stg.order_date = order_date_dim.full_date
    left join shipping_date_dim
        on stg.shipping_date = shipping_date_dim.full_date
    left join payment
        on stg.order_type = payment.type

)

select * from joined


    where order_item_key not in (select order_item_key from SupplyChain_db.marts.fact_order_item)

  )
