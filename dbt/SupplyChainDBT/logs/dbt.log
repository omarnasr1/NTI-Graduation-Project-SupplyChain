        stg.customer_lname,
        stg.customer_street,
        stg.customer_country,
        stg.customer_email,
        stg.customer_password,
        stg.customer_segment
    from stg
    left join geo
        on stg.customer_street    = geo.customer_street
       and stg.customer_state     = geo.customer_state
       and stg.customer_zipcode   = geo.customer_zipcode
       and stg.customer_country   = geo.customer_country
       and stg.customer_city      = geo.customer_city

)


