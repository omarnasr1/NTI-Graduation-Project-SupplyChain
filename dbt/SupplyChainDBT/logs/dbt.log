        coalesce(cast(Unit_Cost_At_Movement as decimal(18,2)), 0)             as unit_cost_at_movement,
        Stock_On_Hand_After_Movement                             as stock_on_hand_after_movement,
        trim(Movement_Type_Name)                                 as movement_type_name,
