),

joined as (

    select
        md5(cast(coalesce(cast(stg.customer_fname as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(stg.customer_lname as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(stg.customer_street as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(stg.customer_country as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as customer_key,
